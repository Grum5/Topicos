<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="dbAccessAvalonia.MainWindow"
        Title="Gestión de Alumnos" Width="400" Height="300">
    <Window.Content>
        <StackPanel Margin="10">
            <TextBlock Text="No. Control:" />
            <TextBox x:Name="txtNoControl" />
            
            <TextBlock Text="Nombre:" />
            <TextBox x:Name="txtNombre" />
            
            <TextBlock Text="Carrera:" />
            <TextBox x:Name="txtCarrera" />
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button x:Name="btnInsertar" Content="Insertar" Margin="5" />
                <Button x:Name="btnActualizar" Content="Actualizar" Margin="5" />
                <Button x:Name="btnBorrar" Content="Borrar" Margin="5" />
            </StackPanel>
            
            <DataGrid x:Name="dgvAlumnos" Height="150" />
        </StackPanel>
    </Window.Content>
</Window>

